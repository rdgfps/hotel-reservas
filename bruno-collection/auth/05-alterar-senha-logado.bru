meta {
  name: Alterar Senha Logado
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/auth/alterar-senha
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "senhaAtual": "Admin@123",
    "novaSenha": "Admin@1234"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000
  token: cole-o-token-do-login
}
